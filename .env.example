## ML-AIR local quickstart environment template
## Copy to `.env` and adjust values if needed.

# Core service connections
ML_AIR_REDIS_URL=redis://redis:6379/0
ML_AIR_DATABASE_URL=postgresql://mlair:mlair@postgres:5432/mlair
ML_AIR_API_BASE_URL=http://api:8080

# API auth/security
ML_AIR_JWT_HS256_SECRET=mlair-dev-jwt-secret-32bytes-minimum-key
ML_AIR_TRACKING_TOKEN=maintainer-token

# Replay + manifest hardening
ML_AIR_REPLAY_REQUIRE_ARTIFACT_EVIDENCE=1
ML_AIR_REPLAY_REQUIRE_CHECKSUM=0
ML_AIR_REPLAY_REQUIRE_SIGNED_MANIFEST=0
ML_AIR_MANIFEST_SIGNING_KEY=mlair-dev-manifest-signing-key
ML_AIR_MANIFEST_ACTIVE_KEY_ID=v1
ML_AIR_MANIFEST_SIGNING_KEYS_JSON={"v1":"mlair-dev-manifest-signing-key"}

# Ports (host)
ML_AIR_FRONTEND_PORT=38080
ML_AIR_API_PORT=8080
ML_AIR_SCHEDULER_METRICS_PORT=9102
ML_AIR_EXECUTOR_METRICS_PORT=9103
ML_AIR_REDIS_PORT=6379
ML_AIR_POSTGRES_PORT=5432
ML_AIR_MINIO_API_PORT=9000
ML_AIR_MINIO_CONSOLE_PORT=9001
ML_AIR_PROMETHEUS_PORT=39090
ML_AIR_GRAFANA_PORT=33000

# Postgres bootstrap
POSTGRES_USER=mlair
POSTGRES_PASSWORD=mlair
POSTGRES_DB=mlair

# MinIO bootstrap
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniopassword

# Grafana bootstrap
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
